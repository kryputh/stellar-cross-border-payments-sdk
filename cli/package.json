    "better-sqlite3": "^11.0.0",
    "bignumber.js": "^9.1.2",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.3",
    "commander": "^12.0.0",
    "csv-parse": "^5.5.0",
    "csv-stringify": "^6.4.0",
    "dotenv": "^16.3.0",
    "inquirer": "^8.2.6",
    "ora": "^5.4.1",
    "pdfkit": "^0.15.0",
    "stellar-base": "^10.0.0",
    "stellar-sdk": "^12.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
